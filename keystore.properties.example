# Copy to keystore.properties (gitignored) and fill in real values to enable release signing.
# Generate the keystore once with:
#   keytool -genkey -v -keystore mtg-ebay-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias mtg-ebay
storeFile=mtg-ebay-release.jks
storePassword=
keyAlias=mtg-ebay
keyPassword=
